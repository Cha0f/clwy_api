# 服务端口
PORT=3000

# 密钥，用于 JWT Token 签发和验证
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secret-key-here

# JWT Token 有效期
JWT_EXPIRES_IN=7d

# 运行环境：development / production / test
NODE_ENV=development

# 允许跨域访问的前端来源，多个来源使用英文逗号分隔（不要在末尾添加路径）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库配置（由 config/env.js 统一读取）
DB_USERNAME=root
DB_PASSWORD=your-db-password
DB_DATABASE=database_development
DB_HOST=127.0.0.1

# Redis 缓存（默认连接本地 6379）
REDIS_URL=redis://localhost:6379

# 文件上传（腾讯云 COS）
COS_ACCESS_KEY_ID=your-cos-secret-id
COS_ACCESS_KEY_SECRET=your-cos-secret-key
COS_BUCKET=your-bucket-name
COS_REGION=ap-shanghai

# `MAILER`开头的配置，为邮件服务器的配置。
MAILER_HOST=邮件服务器地址
MAILER_PORT=邮件服务器端口
MAILER_SECURE=465端口填写：true，否则填写：false
MAILER_USER=你的邮箱地址
MAILER_PASS=你的邮箱授权码或密码
