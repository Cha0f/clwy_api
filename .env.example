# 服务端口
PORT=3000

# 密钥，用于 JWT Token 签发和验证
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secret-key-here

# JWT Token 有效期
JWT_EXPIRES_IN=1h

# 运行环境：development / production / test
NODE_ENV=development

# 数据库连接（二选一）

# 方式一：URL 方式（需 config/config.json 中开启 use_env_variable）
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/clwy_api_development

# 方式二：密码覆盖（优先级高于 config.json 中的 password）
# DB_PASSWORD=your-db-password
